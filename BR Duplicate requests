/**
 * Returns true if any other open work order for the user
 * already has requested_password = true.
 * (Called by Before Insert BR on new work orders)
 */
hasOpenPasswordRequest: function(openedFor) {
    if (!openedFor)
        return false;

    var gr = new GlideRecord('x_banun_property_0_physical_security_work_order');
    gr.addQuery('x_banun_bunow_al_0_opened_for', openedFor);
    gr.addQuery('requested_password', true);
    gr.addActiveQuery();
    gr.setLimit(1);
    gr.query();
    return gr.hasNext();
},







(function executeRule(current, previous /*null when async*/) {
    var helper = new AlarmCodeHelper();
    var openedFor = current.getValue('x_banun_bunow_al_0_opened_for');

    var creds = helper.pullExistingCredentials(openedFor);
    if (creds.found) {
        current.setValue('alarm_code', creds.code);
        current.setValue('alarm_password', creds.password);
    } else if (helper.hasOpenPasswordRequest(openedFor)) {
        // Password already requested on another open record — carry the flag
        current.setValue('requested_password', true);
    }
})(current, previous);
