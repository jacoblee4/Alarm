//HTML

<!-- Vendor-only guard -->
<div ng-if="data.error" class="alert alert-info" tabindex="0">
  ${This page is only for vendors to use.}
</div>
<div ng-if="!data.error">
  <div ng-if="!data.canRead">
    <h4 style="font-size: 13px;">${Record not found}</h4>
  </div>

  <div ng-if="data.canRead" class="panel panel-{{options.color}} b ticket_conversation">
    <!-- Header: task number + short description -->
    <div class="panel-heading buvp wide" role="region" aria-label="${Panel heading}">
      <div class="titles">
        <div class="task-number">
          <h2 style="font-size: 13px;">{{data.number}}</h2>
        </div>
        <h2 style="margin-top: 5px;">
          {{data.short_description}}
        </h2>
      </div>
    </div>

    <div class="panel-body buvp" style="margin-top: -10px;" role="region" aria-label="${Panel body}">
      <div>
        <h2 class="description-title" style="margin-bottom: 10px;">
          ${Description}
        </h2>
        <div class="task-description">
          <div ng-if="!data.description" class="task-description-empty">${(empty)}</div>
          <span ng-if="data.description">{{data.description}}</span>

          <!-- Invoice/Work Order Attached choice - hidden when parent issue_type is alarm_panel -->
          <div ng-if="!data.hideAttach">
            <label class="attachConfirm-label" for="attachConfirm">{{data.attach_label}}</label>
            <div class="attachConfirm-div">
              <sn-choice-list
                              class="attachConfirm-choice"
                              id="attachConfirm"
                              sn-model="c.attached"
                              sn-options="c.attachOptions"
                              sn-value-field="value"
                              sn-text-field="label"
                              sn-items="c.attachChoices"
                              sn-on-change="c.updateAttached(selectedValue)"
                              >
              </sn-choice-list>
            </div>
          </div>
        </div>

        <h3 id="commentsHeading">
          ${Comments}
        </h3>

        <!-- Comment entry + activity stream (only if a readable journal field exists) -->
        <div ng-if="data.hasReadableJournalField">
          <form ng-submit="postEntry(data.journalEntry)" id="sand">
            <div ng-show="data.primaryJournalField" class="input-group" role="group">
              <textarea
                        ng-keypress="keyPress($event)"
                        sn-resize-height="trim"
                        rows="1"
                        id="post-input"
                        class="form-control no-resize"
                        ng-model="data.journalEntry"
                        placeholder="{{getPlaceholder()}}"
                        autocomplete="off"
                        ng-change="userTyping(data.journalEntry)"
                        aria-labelledby="commentsHeading"
                        ></textarea>
              <span class="journal-field-indicator" ng-style="{'background-color': data.useSecondaryJournalField ? data.secondaryJournalField.color : data.primaryJournalField.color}"></span>
              <span class="input-group-btn" style="vertical-align: top;">
                <input type="submit" class="btn btn-primary" value="{{data.btnLabel}}" ng-disabled="!data.journalEntry || data.isPosting" />
              </span>
            </div>
            <!-- Optional secondary journal field toggle (e.g. work notes) -->
            <div ng-if="data.secondaryJournalField && data.secondaryJournalField.can_write">
              <label class="pull-right">
                <input type="checkbox" ng-model="data.useSecondaryJournalField" />
                {{::data.secondaryJournalField.label}}
              </label>
            </div>
          </form>
          <!-- "User is typing" indicators -->
          <ul class="list-group m-b-none" ng-if="typing.length">
            <li class="list-group-item user-typing m-t" ng-repeat="u in typing">${{{::u.user_display_name}} is typing}</li>
          </ul>
          <ul class="list-group m-b-none m-t" ng-if="msg">
            <li class="list-group-item user-typing">{{msg}}</li>
          </ul>

          <!-- Activity timeline -->
          <div class="timeline-container">
            <ul class="timeline">
              <li class="timeline-item" ng-class="{'timeline-inverted': e.user_sys_id == data.stream.user_sys_id} " ng-repeat="e in data.mergedEntries">
                <div class="timeline-badge" tabindex="-1" aria-hidden="true">
                  <sn-avatar primary="e.user_sys_id" class="avatar-large" show-presence="false" enable-context-menu="false"></sn-avatar>
                </div>
                <div class="timeline-panel">
                  <div class="timeline-panel-inner" ng-style="::{'border-color': getFieldColor(e.element)}" aria-label="{{e.ariaLabel}}">
                    <div class="timeline-heading" tabindex="-1" aria-hidden="true">
                      <h4 class="timeline-title">{{::e.name}}</h4>
                      <p>
                        <small class="text-muted">
                          <span class="glyphicon glyphicon-time"></span>
                          <sn-time-ago timestamp="::e.sys_created_on"></sn-time-ago>
                        </small>
                      </p>
                    </div>
                    <div class="timeline-body" tabindex="-1" aria-hidden="true">
                      <!-- Text entry vs. attachment entry -->
                      <p ng-if="e.element != 'attachment'" ng-bind-html="::e.value"></p>
                      <div ng-if="e.element == 'attachment'">
                        <a ng-if="e.attachment.thumbnail_path" target="_blank" href="/sys_attachment.do?view=true&sys_id={{e.attachment.sys_id}}" title="{{dataViewMsg}}">
                          <img alt="" ng-src="/{{e.attachment.path}}?t=medium" class="img-responsive" />
                        </a>
                        <div>
                          <a href="/sys_attachment.do?sys_id={{e.attachment.sys_id}}" target="_blank" title="{{dataViewMsg}}">
                            <strong>{{e.attachment.file_name}}</strong>
                          </a>
                          <br />
                          {{e.attachment.size}}
                        </div>
                      </div>
                    </div>
                  </div>
                </div>
              </li>

              <!-- Record-created anchor entry -->
              <li class="timeline-item timeline-inverted">
                <div class="timeline-badge" tabindex="-1" aria-hidden="true">
                  <sn-avatar primary="data.stream.user_sys_id" class="avatar-large" show-presence="false" enable-context-menu="false"></sn-avatar>
                </div>
                <div class="timeline-panel timeline-panel-first-item" aria-label="{{data.firstMessageAriaLabel}}">
                  <div class="timeline-heading" tabindex="-1" aria-hidden="true">
                    <h4 class="timeline-title">{{data.stream.user_full_name}}</h4>
                    <p>
                      <small class="text-muted">
                        <span class="glyphicon glyphicon-time"></span>
                        <sn-time-ago timestamp="data.created_on"></sn-time-ago>
                      </small>
                    </p>
                  </div>
                  <div class="timeline-body" tabindex="-1" aria-hidden="true">
                    <p>{{data.number}} ${Created}</p>
                  </div>
                </div>
              </li>
              <li class="timeline-start">
                <div class="timeline-badge success">${Start}</div>
              </li>
            </ul>
          </div>
        </div>
        <div ng-if="!data.hasReadableJournalField">{{options.no_readable_journal_field_message}}</div>
      </div>
    </div>
  </div>
</div>










