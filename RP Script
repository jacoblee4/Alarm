(function runProducer(current, producer) {

    var helper = new AlarmCodeHelper();

    current.issue_type = 'alarm_panel';
    current.short_description = 'PSSR: Alarm Panel Request';
    current.description = 'Alarm Panel Request for: ' + producer.opened_for.getDisplayValue();

    var requestType = producer.request_type ? producer.request_type.toString() : '';

    // ADD — encrypted credentials are written after insert by the Business Rule
    // (AlarmCodeHelper.applyInitialCredentials). Nothing encrypted is touched here.
    if (requestType === 'add') {
        current.user_type = helper.getInitialUserType(producer.opened_for.toString());
        return;
    }

    // REMOVE — location fields only (not encrypted, safe to set here)
    if (requestType !== 'remove' || !producer.alarm_code_location) {
        return;
    }

    var loc = helper.getRemoveLocationValues(
        producer.alarm_code_location.toString(),
        producer.issue_at_branch.toString()
    );
    if (!loc.found) {
        return;
    }

    current.branch = loc.branch;
    current.region = loc.region;
    current.building = loc.building;

})(current, producer);
