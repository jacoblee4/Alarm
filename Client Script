function onChange(control, oldValue, newValue, isLoading) {
    if (isLoading) {
        g_form.hideFieldMsg('alarm_code_location', true);
        return;
    }

    // Always clear previous messages when request type changes
    g_form.hideFieldMsg('alarm_code_location', true);
	
    // Only validate when request type is REMOVE
    if (newValue !== 'remove') {
        return;
    }

    // If opened_for is empty, do nothing yet
    var openedFor = g_form.getValue('opened_for');
    if (!openedFor) {
        return;
    }

    var ga = new GlideAjax('x_banun_bunow_al_0.AlarmCodeHelper');
    ga.addParam('sysparm_name', 'hasAlarmCode');
    ga.addParam('sysparm_employee', openedFor);

    ga.getXMLAnswer(function (answer) {
        g_form.hideFieldMsg('alarm_code_location', true);

        if (answer !== 'true') {
            g_form.showFieldMsg(
                'alarm_code_location',
                'No Alarm Code Locations found for this user.',
                'error',
                true
            );
        }
    });
}
