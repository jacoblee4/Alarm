function(scope, elm) {
    // Set the focus back on the input for IE11
    scope.setFocus = function() {
        var input = $(elm[0]).find('textarea#post-input');
        if (input[0])
            input[0].focus();
    };
    $(elem).on('keydown', '.dropdown-toggle', function(e){
        var target = e.target;
        if(e.key == "Tab") {
            $(target).parents('div').removeClass('open');
        }
    });
    $(elem).on('keydown','.dropdown-menu',function(e){
        var target = e.target;
        if (target.localName == 'a') {
            debugger;
            var currentMenuItem = $(target).parents('li');
            var parentUL = currentMenuItem.parents('ul');
            var allMenuItems = parentUL.children('li.contact-link');
            var firstMenuItem = allMenuItems.first();
            var lastMenuItem = allMenuItems.last();
            var menuItemToFocus;
            if(e.key == "Enter") {
                $(target).trigger('click');
            }
            if(e.key == "ArrowUp") {
                e.preventDefault();
                var previousMenuItem = currentMenuItem.prevAll('li.contact-link').first();
                //enable circular navigation
                menuItemToFocus = previousMenuItem.length ? previousMenuItem : lastMenuItem;
                setTimeout(function(){menuItemToFocus.find('a').focus();}, 50);
                
            } else if(e.key == "ArrowDown") {
                e.preventDefault();
                var nextMenuItem = currentMenuItem.nextAll('li.contact-link').first();
                //enable circular navigation
                menuItemToFocus = nextMenuItem.length ? nextMenuItem : firstMenuItem;
                setTimeout(function(){menuItemToFocus.find('a').focus();}, 50);
            }
            if(e.key == "Tab" || e.key == "Escape") {
                $(".dropdown.open").removeClass('open');
            }
        }
    });

}









