(function executeRule(current, previous /*null when async*/) {
    var helper = new AlarmCodeHelper();
    helper.syncAlarmCodeList(current.getUniqueValue());

    // Propagate credentials to other open work orders for this user
    if (current.alarm_password.nil() == false && (!previous || previous.alarm_password.nil() == true)) {
        helper.propagateCredentials(current.getUniqueValue());
    }
})(current, previous);
