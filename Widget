/* =====================================================
   Alarm Widget — Scoped Styles
   ===================================================== */

.aw-password-widget {
  font-family: "Source Sans Pro", "Helvetica Neue", Arial, sans-serif;
  max-width: 480px;
  margin: 40px auto;
  padding: 0 16px;
}

/* ----- Shared State Container ----- */
.aw-state {
  background: #ffffff;
  border-radius: 12px;
  box-shadow: 0 4px 24px rgba(0, 0, 0, 0.08), 0 1px 4px rgba(0, 0, 0, 0.06);
  padding: 40px 36px;
  text-align: center;
}

.aw-state-content {
  animation: aw-fade-in 0.25s ease;
}

@keyframes aw-fade-in {
  from { opacity: 0; }
  to   { opacity: 1; }
}

.aw-state h2 {
  font-size: 22px;
  font-weight: 700;
  color: #1a1f36;
  margin: 16px 0 8px;
}

.aw-state p {
  font-size: 15px;
  color: #525f7f;
  line-height: 1.6;
  margin: 0;
}

/* ----- Icon Circles ----- */
.aw-icon-wrap {
  width: 68px;
  height: 68px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  margin: 0 auto 8px;
  font-size: 32px;
}

.denied-icon    { background: #fff1f0; color: #f5222d; }
.submitted-icon { background: #fff7e6; color: #fa8c16; }
.form-icon      { background: #e6f7ff; color: #1890ff; }
.success-icon   { background: #f6ffed; color: #52c41a; }

/* ----- Loading ----- */
.aw-loading p {
  color: #8c8c8c;
  margin-top: 12px;
}

/* ----- Form Layout ----- */
.aw-form {
  text-align: left;
}

.aw-header {
  text-align: center;
  margin-bottom: 28px;
}

.aw-subtitle {
  font-size: 14px;
  color: #8c96b0;
}

/* ----- Field ----- */
.aw-field-wrap {
  margin-bottom: 20px;
}

.aw-label {
  display: block;
  font-size: 13px;
  font-weight: 600;
  color: #3d4559;
  margin-bottom: 6px;
  letter-spacing: 0.02em;
  text-transform: uppercase;
}

.aw-input-wrap {
  position: relative;
  border-radius: 8px;
  border: 1.5px solid #d9dde8;
  background: #fafbfc;
  transition: border-color 0.2s, box-shadow 0.2s;
}

.aw-input-wrap:focus-within {
  border-color: #1890ff;
  box-shadow: 0 0 0 3px rgba(24, 144, 255, 0.12);
  background: #fff;
}

.aw-input-wrap.has-error {
  border-color: #f5222d;
  box-shadow: 0 0 0 3px rgba(245, 34, 45, 0.1);
}

.aw-input-wrap.has-success {
  border-color: #52c41a;
  box-shadow: 0 0 0 3px rgba(82, 196, 26, 0.1);
}

.aw-input {
  width: 100%;
  padding: 11px 44px 11px 14px;
  border: none;
  background: transparent;
  font-size: 16px;
  color: #1a1f36;
  outline: none;
  box-sizing: border-box;
  border-radius: 8px;
  letter-spacing: 0.05em;
}

.aw-toggle-vis {
  position: absolute;
  right: 10px;
  top: 50%;
  transform: translateY(-50%);
  background: none;
  border: none;
  cursor: pointer;
  color: #8c96b0;
  padding: 4px;
  line-height: 1;
  font-size: 18px;
  transition: color 0.2s;
}

.aw-toggle-vis:hover { color: #1890ff; }

/* ----- Requirements List ----- */
.aw-requirements {
  background: #f5f7fa;
  border-radius: 8px;
  padding: 16px 18px;
  margin-bottom: 24px;
}

.aw-req-title {
  font-size: 12px;
  font-weight: 700;
  text-transform: uppercase;
  letter-spacing: 0.06em;
  color: #8c96b0;
  margin: 0 0 10px;
}

.aw-req-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.aw-req-item {
  display: flex;
  align-items: center;
  gap: 10px;
  font-size: 14px;
  color: #525f7f;
  padding: 5px 0;
  transition: color 0.2s;
}

.aw-req-icon {
  font-size: 17px;
  line-height: 1;
  flex-shrink: 0;
  width: 20px;
  text-align: center;
}

.rule-neutral .aw-req-icon { color: #c0c8d8; }
.rule-pass    { color: #2f9e44; }
.rule-pass    .aw-req-icon { color: #52c41a; }
.rule-fail    { color: #c92a2a; }
.rule-fail    .aw-req-icon { color: #f5222d; }

/* ----- Error Banner ----- */
.aw-error-banner {
  display: flex;
  align-items: center;
  gap: 8px;
  background: #fff1f0;
  border: 1px solid #ffa39e;
  border-radius: 8px;
  padding: 10px 14px;
  color: #c0392b;
  font-size: 14px;
  margin-bottom: 16px;
}

/* ----- Submit Button ----- */
.aw-submit-btn {
  width: 100%;
  padding: 13px;
  background: #1890ff;
  color: #fff;
  border: none;
  border-radius: 8px;
  font-size: 15px;
  font-weight: 600;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8px;
  transition: background 0.2s, opacity 0.2s, transform 0.1s;
}

.aw-submit-btn:hover:not([disabled]) {
  background: #096dd9;
  transform: translateY(-1px);
}

.aw-submit-btn:active:not([disabled]) {
  transform: translateY(0);
}

.aw-submit-btn[disabled] {
  background: #bdc5d4;
  cursor: not-allowed;
}



// ============================================================
// Client Script v1.2
// ============================================================

api.controller = function($location) {
  var c = this;

  // ── State ──────────────────────────────────────────
  c.state        = 'loading';
  c.password     = '';
  c.showPassword = false;
  c.touched      = false;
  c.valid        = false;
  c.submitting   = false;
  c.serverError  = '';
  c.errorMessage = '';

  c.rules = {
    minLength:   false,
    maxLength:   false,
    lettersOnly: false
  };

  // ── Init ───────────────────────────────────────────
  c.$onInit = function() {
    var sysId = $location.search().sys_id || c.options.sys_id || '';

    if (!sysId) {
      c.state        = 'no_record';
      c.errorMessage = 'No reference record found. Please contact an administrator.';
      return;
    }

    c.server.get({ action: 'init', sys_id: sysId }).then(function(r) {
      var d = r.data;
      if (d && d.state) {
        c.state        = d.state;
        c.errorMessage = d.errorMessage || '';
      } else {
        c.state        = 'no_record';
        c.errorMessage = 'Unexpected response. Please contact an administrator.';
      }
    }).catch(function() {
      c.state        = 'no_record';
      c.errorMessage = 'An unexpected error occurred. Please contact an administrator.';
    });
  };

  // ── Password Validation ────────────────────────────
  c.onPasswordChange = function() {
    var p = c.password || '';
    var lettersOnly = /^[A-Za-z]+$/.test(p) && p.length > 0;
    c.rules.minLength   = p.length >= 4 && lettersOnly;
    c.rules.maxLength   = p.length > 0 && p.length <= 10 && lettersOnly;
    c.rules.lettersOnly = lettersOnly;
    c.valid = c.rules.minLength && c.rules.maxLength && c.rules.lettersOnly;
  };

  c.onBlur = function() {
    c.touched = true;
    c.onPasswordChange();
  };

  // ── Submit ─────────────────────────────────────────
  c.submit = function() {
    c.touched = true;
    c.onPasswordChange();

    if (!c.valid || c.submitting) return;

    var sysId = $location.search().sys_id || c.options.sys_id || '';
    c.submitting  = true;
    c.serverError = '';

    c.server.get({
      action:   'submit',
      sys_id:   sysId,
      password: c.password
    }).then(function(r) {
      c.submitting = false;
      if (r.data.success) {
        c.state = 'success';
      } else if (r.data.state === 'error') {
        c.state = 'error';
      } else {
        c.serverError = r.data.error || 'An unexpected error occurred. Please try again.';
      }
    }).catch(function() {
      c.submitting = false;
      c.state      = 'error';
    });
  };

};




// ============================================================
// Server Script v1.5
// ============================================================

(function() {
  data.state   = '';
  data.success = false;
  data.error   = '';

  // ── Guard: input object safety check ──────────────
  if (!input || typeof input !== 'object') {
    data.state        = 'no_record';
    data.errorMessage = 'No reference record found. Please contact an administrator.';
    return;
  }

  var action = input.action;
  var sysId  = input.sys_id;

  // ── Guard: must have a sys_id ──────────────────────
  if (!sysId) {
    data.state        = 'no_record';
    data.errorMessage = 'No reference record found. Please contact an administrator.';
    return;
  }

  // ── Load the work order record ─────────────────────
  var wo = new GlideRecord('x_banun_property_0_physical_security_work_order');
  if (!wo.get(sysId)) {
    data.state = 'denied';
    return;
  }

  // ── Check: request type must be 'add' ─────────────
  var requestType = wo.getValue('request_type');
  if (!requestType || requestType.toLowerCase() !== 'add') {
    data.state = 'wrong_type';
    return;
  }

  // ── Check: already submitted? ──────────────────────
  var alarmPassword = wo.getValue('alarm_password');
  if (alarmPassword && alarmPassword.trim() !== '') {
    data.state = 'submitted';
    return;
  }

  // ── Check: logged-in user matches opened_for ───────
  var openedForSysId = wo.getValue('x_banun_bunow_al_0_opened_for');
  var currentUser    = gs.getUserID();

  if (openedForSysId !== currentUser) {
    data.state = 'denied';
    return;
  }

  // ── INIT action ────────────────────────────────────
  if (action === 'init') {
    data.state = 'form';
    return;
  }

  // ── SUBMIT action ──────────────────────────────────
  if (action === 'submit') {
    var password = input.password || '';

    // Server-side validation (never trust client alone)
    if (!password.match(/^[A-Za-z]{4,10}$/)) {
      data.success = false;
      data.error   = 'Invalid password. Must be 4–10 letters with no numbers or special characters.';
      return;
    }

    // Re-fetch to confirm it hasn't been submitted since page load
    var fresh = new GlideRecord('x_banun_property_0_physical_security_work_order');
    if (!fresh.get(sysId)) {
      data.success = false;
      data.error   = 'Work order record could not be found.';
      return;
    }

    var latestPw = fresh.getValue('alarm_password');
    if (latestPw && latestPw.trim() !== '') {
      data.success = false;
      data.state   = 'submitted';
      data.error   = 'A password has already been submitted for this record.';
      return;
    }

    // Write the password to the record
    fresh.setValue('alarm_password', password);
    fresh.update();

    // Verify the encrypted field was actually written by re-reading it
    var verify = new GlideRecord('x_banun_property_0_physical_security_work_order');
    if (!verify.get(sysId) || !verify.getValue('alarm_password')) {
      data.success = false;
      data.state   = 'error';
      return;
    }

    data.success = true;
    return;
  }

  // Fallback
  data.state = 'denied';

})();

