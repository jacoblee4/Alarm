// ============================================================
// HTML v1.7
// ============================================================

<div class="aw-password-widget">

  <div class="aw-state"
    ng-class="{
      'aw-loading':   c.state === 'loading',
      'aw-denied':    c.state === 'no_record' || c.state === 'wrong_type' || c.state === 'denied' || c.state === 'error',
      'aw-submitted': c.state === 'submitted',
      'aw-form':      c.state === 'form',
      'aw-success':   c.state === 'success'
    }">

    <!-- ===== LOADING ===== -->
    <div ng-if="c.state === 'loading'" class="aw-state-content">
      <i class="fa fa-spinner fa-spin fa-2x"></i>
      <p>Loading...</p>
    </div>

    <!-- ===== NO RECORD ===== -->
    <div ng-if="c.state === 'no_record'" class="aw-state-content">
      <div class="aw-icon-wrap denied-icon">
        <i class="fa fa-times-circle"></i>
      </div>
      <h2>No Record Found</h2>
      <p>{{c.errorMessage || 'No reference record found. Please contact an administrator.'}}</p>
    </div>

    <!-- ===== WRONG TYPE ===== -->
    <div ng-if="c.state === 'wrong_type'" class="aw-state-content">
      <div class="aw-icon-wrap denied-icon">
        <i class="fa fa-times-circle"></i>
      </div>
      <h2>No Password Required</h2>
      <p>This record does not need a password submitted. Password setup is only required for alarm additions.</p>
    </div>

    <!-- ===== ACCESS DENIED ===== -->
    <div ng-if="c.state === 'denied'" class="aw-state-content">
      <div class="aw-icon-wrap denied-icon">
        <i class="fa fa-times-circle"></i>
      </div>
      <h2>Access Restricted</h2>
      <p>Only the <strong>Opened For</strong> user assigned to this work order can view and submit this content.</p>
    </div>

    <!-- ===== ALREADY SUBMITTED ===== -->
    <div ng-if="c.state === 'submitted'" class="aw-state-content">
      <div class="aw-icon-wrap submitted-icon">
        <i class="fa fa-check-circle"></i>
      </div>
      <h2>Password Already Submitted</h2>
      <p>A password has already been submitted to the alarm panel team. Please wait for a follow-up email indicating your alarm code and password have been created.</p>
    </div>

    <!-- ===== PASSWORD FORM ===== -->
    <div ng-if="c.state === 'form'" class="aw-state-content">
      <div class="aw-header">
        <div class="aw-icon-wrap form-icon">
          <i class="fa fa-unlock"></i>
        </div>
        <h2>Set Your Alarm Password</h2>
        <p class="aw-subtitle">Please create a password for your alarm code below.</p>
      </div>

      <!-- Requirements Checklist -->
      <div class="aw-requirements">
        <p class="aw-req-title">Password Requirements</p>
        <ul class="aw-req-list">
          <li class="aw-req-item" ng-class="!c.password ? 'rule-neutral' : (c.rules.minLength ? 'rule-pass' : 'rule-fail')">
            <span class="aw-req-icon">
              <i ng-if="!c.password" class="fa fa-circle-o"></i>
              <i ng-if="c.password && c.rules.minLength" class="fa fa-check"></i>
              <i ng-if="c.password && !c.rules.minLength" class="fa fa-times"></i>
            </span>
            Minimum 4 letters
          </li>
          <li class="aw-req-item" ng-class="!c.password ? 'rule-neutral' : (c.rules.maxLength ? 'rule-pass' : 'rule-fail')">
            <span class="aw-req-icon">
              <i ng-if="!c.password" class="fa fa-circle-o"></i>
              <i ng-if="c.password && c.rules.maxLength" class="fa fa-check"></i>
              <i ng-if="c.password && !c.rules.maxLength" class="fa fa-times"></i>
            </span>
            Maximum 10 letters
          </li>
          <li class="aw-req-item" ng-class="!c.password ? 'rule-neutral' : (c.rules.lettersOnly ? 'rule-pass' : 'rule-fail')">
            <span class="aw-req-icon">
              <i ng-if="!c.password" class="fa fa-circle-o"></i>
              <i ng-if="c.password && c.rules.lettersOnly" class="fa fa-check"></i>
              <i ng-if="c.password && !c.rules.lettersOnly" class="fa fa-times"></i>
            </span>
            Letters only — no numbers or special characters
          </li>
        </ul>
      </div>

      <!-- Password Field -->
      <div class="aw-field-wrap">
        <label class="aw-label" for="alarmPassword">Password</label>
        <div class="aw-input-wrap" ng-class="{'has-error': c.touched && !c.valid, 'has-success': c.touched && c.valid}">
          <input
            id="alarmPassword"
            type="{{c.showPassword ? 'text' : 'password'}}"
            class="aw-input"
            ng-model="c.password"
            ng-change="c.onPasswordChange()"
            ng-blur="c.onBlur()"
            placeholder="Enter your password"
            autocomplete="new-password"
            maxlength="10"
          />
          <button class="aw-toggle-vis" ng-click="c.showPassword = !c.showPassword" type="button" aria-label="Toggle password visibility">
            <i ng-class="c.showPassword ? 'fa fa-eye-slash' : 'fa fa-eye'"></i>
          </button>
        </div>
      </div>

      <!-- Error Banner -->
      <div class="aw-error-banner" ng-if="c.serverError">
        <i class="fa fa-exclamation-triangle"></i>
        {{c.serverError}}
      </div>

      <!-- Submit Button -->
      <button
        class="aw-submit-btn"
        ng-click="c.submit()"
        ng-disabled="!c.valid || c.submitting"
        type="button"
      >
        <span ng-if="!c.submitting">Submit Password</span>
        <span ng-if="c.submitting"><i class="fa fa-spinner fa-spin"></i> Submitting...</span>
      </button>
    </div>

    <!-- ===== SUCCESS ===== -->
    <div ng-if="c.state === 'success'" class="aw-state-content">
      <div class="aw-icon-wrap success-icon">
        <i class="fa fa-check-circle"></i>
      </div>
      <h2>Thank You!</h2>
      <p>Your response has been sent to the alarm panel team. Please wait for a follow-up email indicating your alarm code and password have been created.</p>
    </div>

    <!-- ===== ERROR ===== -->
    <div ng-if="c.state === 'error'" class="aw-state-content">
      <div class="aw-icon-wrap denied-icon">
        <i class="fa fa-times-circle"></i>
      </div>
      <h2>Something Went Wrong</h2>
      <p>Your password could not be saved. Please contact an administrator for assistance.</p>
    </div>

  </div>

</div>




