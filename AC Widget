//HTML

<div ng-if="data.error" class="alert alert-info" tabindex="0">
    ${This page is only for vendors to use.}
</div>

<div ng-if="!data.error" class="panel panel-{{::options.color}} b svdp" role="region" aria-labelledby="task-information-title">
    <div class="panel-heading buvp">
        <h2 id="task-information-title" class="panel-title">
            <fa ng-if="::options.glyph.length" name="{{::options.glyph}}" class="m-r-sm"></fa>
            {{data.title}}
        </h2>
    </div>

    <div class="panel-body" style="padding-bottom: 0;">
        <div class="details">
            <div class="col-sm-6 field" ng-repeat="field in data.fields">
                <span class="field-value">
                    <label class="m-n">{{field.label}}</label>
                    <div>{{field.display_value}}</div>
                </span>
            </div>
        </div>
    </div>
</div>









// CSS

label {
  font-weight: bold; 
}

div.details {
  color: $dark-text-color;
}

.panel-heading {
  padding: 15px 20px 10px;
}

div.details label{
  color: #555;
  font-weight: 600;
}

div.field {
  padding: 0 !important;
  padding-right: 1px!important;
  margin-bottom: 5px;
}

span.field-value {
  min-height: 44px;
  display: block;
}










// server script

(function() {
    data.error = false;
    var contact = new GlideRecordSecure("vm_vdr_contact");
    if (!contact.get(gs.getUserID()) || !gs.getUser().hasRole('vendor_contact')) {
        data.error = true;
        return;
    }

    var table = $sp.getParameter("table");
    var sys_id = $sp.getParameter("sys_id");

    data.title = "${Record Information}";

    var record = new GlideRecordSecure(table);
    if (!record.get(sys_id))
        return;

    var api = new x_banun_property_0.BUVPVendorPortalUtils();
    if (!api.vendorContactHasAccess(record))
        return;

    data.title = "${Alarm Panel Details}";

    var fieldsInfo = [];

    // Pull the parent record off the current record's reference field
    var parent = record.parent.getRefRecord();
    if (parent && parent.isValidRecord()) {
        var field = {};
        field.name = 'request_type';
        field.label = parent.request_type.getLabel();
        field.value = parent.getValue('request_type');          // "add" or "remove"
        field.display_value = parent.request_type.getDisplayValue(); // "Add" or "Remove"

        if (field.value) {
            fieldsInfo.push(field);
        }
    }

    data.fields = fieldsInfo;
})();








// Client script
function($scope, spUtil) {
    $scope.$on('record.updated', function(name, data) {
        spUtil.update($scope);
    });

    var c = this;
}
