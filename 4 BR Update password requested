When: after update

filter coniditon: requested password changess to true AND issue type is alarm panel request

script:

(function executeRule(current, previous /*null when async*/ ) {

    var gr = new GlideRecord('x_banun_property_0_physical_security_work_order');

    gr.addActiveQuery();
    gr.addQuery('issue_type', 'alarm_panel');
    gr.addQuery('x_banun_bunow_al_0_opened_for', current.x_banun_bunow_al_0_opened_for);
    gr.addQuery('requested_password', false);

    // Exclude the current record
    gr.addQuery('sys_id', '!=', current.sys_id);

    gr.query();

    while (gr.next()) {
        gr.requested_password = true;
        gr.work_notes = 'Password request email was triggered from: ' + current.number;
        gr.setWorkflow(false);
        gr.update();
    }

})(current, previous);
